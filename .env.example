# --- Supabase (el Core usa la service_role key: se salta el RLS por diseño) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# --- JWT ---
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Servidor ---
# En local se usa 8003. En Koyeb el puerto lo inyecta la plataforma vía $PORT.
PORT=8003

# --- CORS ---
# Orígenes permitidos separados por comas. Agregar la URL del frontend (Vercel)
# en producción, p. ej.: http://localhost:5173,https://mi-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Negocio ---
# UUID de un asesor real en asesores_negocio para solicitudes sin asesor asignado.
ASESOR_SIN_ASIGNAR_ID=
